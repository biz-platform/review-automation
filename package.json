{
  "name": "review-automation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "worker": "tsx --no-cache scripts/worker.ts",
    "worker:pm2:start": "pnpm exec pm2 start ecosystem.config.cjs --only review-worker",
    "worker:pm2:restart": "pnpm exec pm2 restart review-worker",
    "worker:pm2:stop": "pnpm exec pm2 stop review-worker",
    "worker:pm2:delete": "pnpm exec pm2 delete review-worker",
    "worker:pm2:logs": "pnpm exec pm2 logs review-worker --lines 200",
    "worker:pm2:save": "pnpm exec pm2 save",
    "archive-reviews": "npx tsx scripts/archive-old-reviews.ts"
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/mcp-server-supabase": "^0.6.3",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "coolsms-node-sdk": "^2.1.0",
    "date-fns": "^4.1.0",
    "next": "^16.1.6",
    "openai": "^6.21.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.3",
    "standardwebhooks": "^1.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^16.4.5",
    "eslint": "^10.0.0",
    "eslint-config-next": "^16.1.6",
    "playwright": "^1.49.0",
    "pm2": "^6.0.14",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2"
  }
}
