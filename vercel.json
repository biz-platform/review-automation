{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/scheduled-auto-register",
      "schedule": "0 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "oliview.kr" }],
      "destination": "https://oliview.kr/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.oliview.kr" }],
      "destination": "https://oliview.kr/:path*",
      "permanent": true
    }
  ]
}
